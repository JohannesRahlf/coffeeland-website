# Git LFS configuration for image files
# This keeps the repository lean by storing images in LFS instead of git history

# Image formats
*.png filter=lfs diff=lfs merge=lfs -text
*.jpg filter=lfs diff=lfs merge=lfs -text
*.jpeg filter=lfs diff=lfs merge=lfs -text
*.gif filter=lfs diff=lfs merge=lfs -text
*.webp filter=lfs diff=lfs merge=lfs -text
*.svg filter=lfs diff=lfs merge=lfs -text

# SVG can also be treated as text if preferred for version control
# Uncomment the line below and comment out the SVG line above to track SVG as text
# *.svg diff=image

# Pages CMS needs real image blobs for previews; do not store static site images as LFS pointers.
static/images/** -filter -diff -merge -text

